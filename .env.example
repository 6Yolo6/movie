# ============================================================
# Gying Movie - Production Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git!
# ============================================================

# --- Database (Cloud MySQL) ---
DB_HOST=your-cloud-mysql-host.com
DB_PORT=3306
DB_NAME=gying
DB_USER=gying_app
DB_PASSWORD=your-strong-db-password

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=gyingredis2024

# --- Image Storage (Cloud OSS / S3) ---
# Alibaba Cloud OSS example:
#   MINIO_URL_PREFIX=https://gying-images.oss-cn-hangzhou.aliyuncs.com/
# Tencent Cloud COS example:
#   MINIO_URL_PREFIX=https://gying-images-1234567890.cos.ap-shanghai.myqcloud.com/
# Keep using MinIO:
#   MINIO_URL_PREFIX=https://minio.yourdomain.com/gying/
MINIO_URL_PREFIX=https://your-cdn-or-oss-domain.com/

# --- CORS ---
# Your production frontend domain
CORS_ALLOWED_ORIGIN=https://yourdomain.com

# --- JWT ---
# IMPORTANT: Generate a strong random secret (at least 32 bytes)
# Example: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_32_BYTES
JWT_EXPIRATION_MS=86400000
